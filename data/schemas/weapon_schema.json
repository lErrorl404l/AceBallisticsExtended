{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/lErrorl404l/AceBallisticsExtended/schemas/weapon",
  "title": "ABE Weapon Configuration",
  "description": "Weapon barrel and chamber configuration matching the WeaponConfig Rust struct",
  "type": "object",
  "required": ["class", "caliber_mm", "barrel_length_mm", "chamber_pressure_mpa"],
  "additionalProperties": false,
  "properties": {
    "class": {
      "type": "string",
      "description": "CfgWeapons class name (e.g. rhs_weap_m4a1)",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
    },
    "caliber_mm": {
      "type": "number",
      "description": "Barrel caliber in millimeters",
      "exclusiveMinimum": 0,
      "maximum": 200
    },
    "barrel_length_mm": {
      "type": "number",
      "description": "Barrel length in millimeters",
      "exclusiveMinimum": 0,
      "maximum": 2000
    },
    "rifling_twist_mm": {
      "type": "number",
      "description": "Rifling twist rate in mm per revolution (e.g. 178 for 1:7\"). Alias: twist_rate_mm",
      "default": 0,
      "exclusiveMinimum": 0,
      "maximum": 2000
    },
    "chamber_pressure_mpa": {
      "type": "number",
      "description": "Peak chamber pressure in MPa (SAAMI/CIP)",
      "exclusiveMinimum": 0,
      "maximum": 700
    },
    "cdm_id": {
      "type": "string",
      "description": "Drag model curve identifier (default: g7)",
      "default": "g7"
    },
    "muzzle_velocity_ms": {
      "type": "number",
      "description": "Published muzzle velocity in m/s (optional, for reference)",
      "default": 0,
      "exclusiveMinimum": 0,
      "maximum": 2500
    },
    "zero_range_m": {
      "type": "number",
      "description": "Zero range in meters (default: 100)",
      "default": 100,
      "minimum": 0,
      "maximum": 1000
    }
  }
}
