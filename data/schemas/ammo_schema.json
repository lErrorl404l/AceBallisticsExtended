{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/lErrorl404l/AceBallisticsExtended/schemas/ammo",
  "title": "ABE Ammo Configuration",
  "description": "Ammunition/projectile configuration matching the AmmoConfig and ProjectileConfig Rust structs",
  "type": "object",
  "required": ["class", "projectile"],
  "additionalProperties": false,
  "properties": {
    "class": {
      "type": "string",
      "description": "CfgAmmo class name (e.g. rhs_mag_30Rnd_556x45_M855_Stanag)",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
    },
    "projectile": {
      "type": "object",
      "description": "Projectile physical and ballistic properties",
      "required": ["model", "mass_g", "caliber_mm", "bc_g7"],
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "description": "Projectile model name (e.g. M855, M80)"
        },
        "mass_g": {
          "type": "number",
          "description": "Projectile mass in grams",
          "exclusiveMinimum": 0,
          "maximum": 50000
        },
        "caliber_mm": {
          "type": "number",
          "description": "Projectile caliber in millimeters",
          "exclusiveMinimum": 0,
          "maximum": 200
        },
        "bc_g7": {
          "type": "number",
          "description": "Ballistic coefficient for the G7 drag model",
          "exclusiveMinimum": 0,
          "maximum": 10
        },
        "cdm_id": {
          "type": "string",
          "description": "Drag model curve identifier (default: g7)",
          "default": "g7"
        },
        "fragmentation": {
          "type": "object",
          "description": "Optional fragmentation parameters",
          "required": ["threshold_vel_ms", "avg_fragments", "mass_distribution", "params"],
          "additionalProperties": false,
          "properties": {
            "threshold_vel_ms": {
              "type": "number",
              "description": "Minimum impact velocity for fragmentation (m/s)",
              "exclusiveMinimum": 0
            },
            "avg_fragments": {
              "type": "integer",
              "description": "Average number of fragments generated",
              "minimum": 0
            },
            "mass_distribution": {
              "type": "string",
              "description": "Mass distribution model (e.g. log_normal)",
              "enum": ["log_normal", "uniform", "mott"]
            },
            "params": {
              "type": "object",
              "description": "Distribution parameters (e.g. {\"mean\": 0.08, \"std\": 0.04})",
              "minProperties": 1
            }
          }
        },
        "frag_mass_mean": {
          "type": "number",
          "description": "Mean fragment mass in grams for log-normal distribution (0 = auto)",
          "default": null
        },
        "frag_mass_std": {
          "type": "number",
          "description": "Standard deviation of fragment mass in grams (0 = auto)",
          "default": null
        },
        "ricochet_angle_deg": {
          "type": "number",
          "description": "Maximum ricochet angle in degrees; 0 uses default calc",
          "default": null,
          "minimum": 0,
          "maximum": 90
        },
        "tracer_burn_time_s": {
          "type": "number",
          "description": "Tracer burn duration in seconds; 0 or null = no tracer",
          "default": null,
          "minimum": 0
        },
        "incendiary": {
          "type": "boolean",
          "description": "Whether projectile has incendiary effect",
          "default": null
        },
        "incendiary_ignition_temp_k": {
          "type": "number",
          "description": "Ignition temperature of incendiary filler in Kelvin",
          "default": null,
          "exclusiveMinimum": 0
        },
        "sabot_mass_g": {
          "type": "number",
          "description": "Sabot/pusher mass in grams (for APFSDS discarding sabot rounds)",
          "default": null,
          "exclusiveMinimum": 0
        },
        "sabot_discard_velocity_ms": {
          "type": "number",
          "description": "Velocity at which sabot petals separate (m/s)",
          "default": null,
          "exclusiveMinimum": 0
        },
        "apfsds_tip_length_mm": {
          "type": "number",
          "description": "APFSDS stepped-tip length in millimeters",
          "default": null,
          "exclusiveMinimum": 0
        },
        "apfsds_tip_mass_g": {
          "type": "number",
          "description": "APFSDS stepped-tip mass in grams",
          "default": null,
          "exclusiveMinimum": 0
        },
        "apfsds_tip_shedding_velocity_ms": {
          "type": "number",
          "description": "Minimum impact velocity (m/s) for the tip to shear off",
          "default": null,
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
